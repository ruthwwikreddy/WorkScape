rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - name: string (required) - User's display name
    //   - avatarConfig: map (required) - Avatar configuration
    //   - lastPos: map (optional) - Last known position
    //   - updatedAt: timestamp (optional)
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - uid: string (required) - Owner's UID
    //   - text: string (required) - Task description
    //   - done: bool (required) - Completion status
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'avatarConfig']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.avatarConfig is map;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['uid', 'text', 'done']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.done is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasOnlyAllowedFields(['id', 'name', 'password', 'isPublic', 'createdBy', 'createdAt']) &&
                    request.resource.data.id == roomId &&
                    request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
